  langid = {english},
  keywords = {Computer Science - Computer Vision and Pattern Recognition,Computer Science - Graphics,Computer Science - Machine Learning},
  file = {/home/sebastian/Zotero/storage/CMVK5ILK/Müller et al. - 2022 - Instant Neural Graphics Primitives with a Multiresolution Hash Encoding.pdf}
}

@misc{niuSharpNetEnhancingMLPs2026,
  title = {{{SharpNet}}: {{Enhancing MLPs}} to {{Represent Functions}} with {{Controlled Non-differentiability}}},
  shorttitle = {{{SharpNet}}},
  author = {Niu, Hanting and Deng, Junkai and Hou, Fei and Wang, Wencheng and He, Ying},
  year = 2026,
  month = jan,
  number = {arXiv:2601.19683},
  eprint = {2601.19683},
  primaryclass = {cs},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2601.19683},
  urldate = {2026-03-17},
  abstract = {Multi-layer perceptrons (MLPs) are a standard tool for learning and function approximation, but they inherently yield outputs that are globally smooth. As a result, they struggle to represent functions that are continuous yet deliberately non-differentiable (i.e., with prescribed \$C\textasciicircum 0\$ sharp features) without relying on ad hoc post-processing. We present SharpNet, a modified MLP architecture capable of encoding functions with user-defined sharp features by enriching the network with an auxiliary feature function, which is defined as the solution to a Poisson equation with jump Neumann boundary conditions. It is evaluated via an efficient local integral that is fully differentiable with respect to the feature locations, enabling our method to jointly optimize both the feature locations and the MLP parameters to recover the target functions/models. The \$C\textasciicircum 0\$-continuity of SharpNet is precisely controllable, ensuring \$C\textasciicircum 0\$-continuity at the feature locations and smoothness elsewhere. We validate SharpNet on 2D problems and 3D CAD model reconstruction, and compare it against several state-of-the-art baselines. In both types of tasks, SharpNet accurately recovers sharp edges and corners while maintaining smooth behavior away from those features, whereas existing methods tend to smooth out gradient discontinuities. Both qualitative and quantitative evaluations highlight the benefits of our approach.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Computer Vision and Pattern Recognition},
  file = {/home/sebastian/Zotero/storage/9H7A9UCK/Niu et al. - 2026 - SharpNet Enhancing MLPs to Represent Functions with Controlled Non-differentiability.pdf;/home/sebastian/Zotero/storage/5FT8J3X9/2601.html}
}

@misc{rangarajanSIEDDSharedImplicitEncoder2025,
  title = {{{SIEDD}}: {{Shared-Implicit Encoder}} with {{Discrete Decoders}}},
  shorttitle = {{{SIEDD}}},
  author = {Rangarajan, Vikram and Maiya, Shishira and Ehrlich, Max and Shrivastava, Abhinav},
  year = 2025,
  month = jun,
  number = {arXiv:2506.23382},
  eprint = {2506.23382},
