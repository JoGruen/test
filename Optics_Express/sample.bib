@article{Yelin:03,
author = {Dvir Yelin and Dan Oron and Stephan Thiberge and Elisha Moses and Yaron Silberberg},
journal = {Opt. Express},
keywords = {Imaging systems; Scanning microscopy; Multiharmonic generation},
number = {12},
pages = {1385--1391},
publisher = {Optica},
title = {Multiphoton plasmon-resonance microscopy},
volume = {11},
month = {Jun},
year = {2003},
url = {http://www.opticsexpress.org/abstract.cfm?URI=oe-11-12-1385},
doi = {10.1364/OE.11.001385},
abstract = {A novel method for detection of noble-metal nanoparticles by their nonlinear optical properties is presented and applied for specific labeling of cellular organelles. When illuminated by laser light in resonance with their plasmon frequency these nanoparticles generate an enhanced multiphoton signal. This enhanced signal is measured to obtain a depth-resolved image in a laser scanning microscope setup. Plasmon-resonance images of both live and fixed cells, showing specific labeling of cellular organelles and membranes, either by two-photon autofluorescence or by third-harmonic generation, are presented.},
}

@article{Masajada:13,
author = {Jan Masajada and Marcin Bacia and S{\l}awomir Drobczy\'{n}ski},
journal = {Opt. Lett.},
keywords = {Laser trapping; Nanomaterials; Ferroelectrics},
number = {19},
pages = {3910--3913},
publisher = {Optica},
title = {Cluster formation in ferrofluids induced by holographic optical tweezers},
volume = {38},
month = {Oct},
year = {2013},
url = {https://opg.optica.org/ol/abstract.cfm?URI=ol-38-19-3910},
doi = {10.1364/OL.38.003910},
abstract = {Holographic optical tweezers were used to show the interaction between a strongly focused laser beam and magnetic nanoparticles in ferrofluid. When the light intensity was high enough, magnetic nanoparticles were removed from the beam center and formed a dark ring. The same behavior was observed when focusing vortex or Bessel beams. The interactions between two or more separated rings of magnetic nanoparticles created by independent optical traps were also observed.},
}

